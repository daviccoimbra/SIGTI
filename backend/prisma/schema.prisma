generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Setor {
  ADMIN
  GESTAO
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  password     String
  nome         String
  email        String?
  departamento String?
  cargo        String?
  setor        Setor
  ativo        Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}


model Ticket {
  id            String     @id @default(uuid())
  protocolo     String     @unique
  solicitante   String
  requesterId   String?
  requester     Requester? @relation(fields: [requesterId], references: [id])
  departamento  String
  categoryId    String?
  category      Category?  @relation(fields: [categoryId], references: [id])
  equipmentId   String?
  equipment     Equipment? @relation(fields: [equipmentId], references: [id])
  titulo        String
  descricao     String
  classificacao String?
  prioridade    String
  status        String     @default("backlog")
  isArchived    Boolean    @default(false)
  anexo         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  comments      Comment[]
  history       History[]
}

model Category {
  id        String   @id @default(uuid())
  descricao String
  tickets   Ticket[]
  createdAt DateTime @default(now())
}

model Equipment {
  id          String   @id @default(uuid())
  nome        String
  marcaModelo String
  unidade     String
  setor       String
  tickets     Ticket[]
  createdAt   DateTime @default(now())
}

model Requester {
  id        String   @id @default(uuid())
  nome      String
  cargo     String
  unidade   String
  setor     String
  createdAt DateTime @default(now())
  tickets   Ticket[]
}

model Comment {
  id       String   @id @default(uuid())
  user     String
  message  String
  date     DateTime @default(now())
  ticketId String
  ticket   Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model History {
  id       String   @id @default(uuid())
  from     String
  to       String
  user     String
  date     DateTime @default(now())
  ticketId String
  ticket   Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}
